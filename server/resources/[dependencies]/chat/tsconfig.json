{
  "compilerOptions": {
    "target": "es5",
    "module": "esnext",
    "moduleResolution": "node",
    "strict": false,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "lib": ["dom", "es2017"],
    "types": ["webpack-env"],
    "typeRoots": ["./node_modules/@types"]
  },
  "include": [
    "html/**/*.ts",
    "html/**/*.vue"
  ]
}
